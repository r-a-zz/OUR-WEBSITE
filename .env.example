# For local development, place environment variables in the server/.env file
# Example server/.env entries:
# YOUTUBE_API_KEY=your_api_key_here
# PORT=5000
# YOUTUBE_API_TIMEOUT_MS=10000
# CORS_ORIGIN=http://localhost:5173
# API_CACHE_MAX_ENTRIES=250
# API_CACHE_SEARCH_TTL_MS=120000
# API_CACHE_VIDEO_TTL_MS=600000
# API_CACHE_TRENDING_TTL_MS=180000
# API_RATE_LIMIT_WINDOW_MS=60000
# API_RATE_LIMIT_MAX_REQUESTS=120
# API_RATE_LIMIT_SEARCH_MAX_REQUESTS=60
# API_RATE_LIMIT_VIDEO_MAX_REQUESTS=90
# API_RATE_LIMIT_TRENDING_MAX_REQUESTS=60
# API_RATE_LIMIT_METRICS_MAX_REQUESTS=30
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_URL=rediss://redis-host:6379
# REDIS_USERNAME=default
# REDIS_PASSWORD=your_redis_password
# REDIS_CONNECT_TIMEOUT_MS=1500
# REDIS_RETRY_BASE_DELAY_MS=150
# REDIS_RETRY_MAX_DELAY_MS=2000
# REDIS_KEY_PREFIX=ourwebsite:
# REDIS_TLS_ENABLED=true
# REDIS_TLS_REJECT_UNAUTHORIZED=true
# METRICS_ENABLED=true
# NODE_ENV=development

YOUTUBE_API_KEY=
PORT=5000
YOUTUBE_API_TIMEOUT_MS=10000
CORS_ORIGIN=http://localhost:5173
API_CACHE_MAX_ENTRIES=250
API_CACHE_SEARCH_TTL_MS=120000
API_CACHE_VIDEO_TTL_MS=600000
API_CACHE_TRENDING_TTL_MS=180000
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=120
API_RATE_LIMIT_SEARCH_MAX_REQUESTS=60
API_RATE_LIMIT_VIDEO_MAX_REQUESTS=90
API_RATE_LIMIT_TRENDING_MAX_REQUESTS=60
API_RATE_LIMIT_METRICS_MAX_REQUESTS=30
REDIS_URL=
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_CONNECT_TIMEOUT_MS=1500
REDIS_RETRY_BASE_DELAY_MS=150
REDIS_RETRY_MAX_DELAY_MS=2000
REDIS_KEY_PREFIX=ourwebsite:
REDIS_TLS_ENABLED=false
REDIS_TLS_REJECT_UNAUTHORIZED=true
METRICS_ENABLED=true
NODE_ENV=development
